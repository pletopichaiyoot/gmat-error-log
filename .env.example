# Server
HOST=127.0.0.1
PORT=4310
SCRAPE_TODAY_BUFFER_HOURS=36

# PostgreSQL (local Docker). For a hosted instance, change only this line.
DATABASE_URL=postgres://postgres:gmat@localhost:5432/gmat
# Legacy SQLite path — used ONLY by the one-time ETL and rollback, not at runtime.
GMAT_DB_PATH=./data/gmat-error-log.db
# Optional security flags
# EXPOSE_INTERNAL_DEBUG=false
# ALLOW_REMOTE_CDP=false

# AI Provider Selection
# openai | zai | (blank = auto detect from available keys)
LLM_PROVIDER=openai

# Option A: OpenAI (official)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
# Optional (leave empty for default OpenAI endpoint)
# OPENAI_API_BASE=

# Option B: Z AI (OpenAI-compatible API)
# LLM_PROVIDER=zai
# ZAI_API_KEY=your_zai_api_key
# ZAI_API_BASE=https://api.z.ai/api/paas/v4/
# ZAI_MODEL=glm-5

# Optional aliases (for compatibility)
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# Optional tuning
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1000

# Optional: separate model for question classification only.
# Classifier shares the same provider, API key, and API base settings above.
# CLASSIFIER_OPENAI_MODEL=gpt-4o-mini
# CLASSIFIER_ZAI_MODEL=glm-5

# Memory (mem0) — persistent coaching memory across sessions
# MEM0_ENABLED=true
# MEM0_MODEL=gpt-4o-mini
