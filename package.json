{
  "name": "gmat-error-log",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev:api": "node --watch src/server.js",
    "dev:web": "vite --config client/vite.config.js",
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "build:web": "vite build --config client/vite.config.js",
    "preview:web": "vite preview --config client/vite.config.js"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4.21.2",
    "lucide-react": "^0.577.0",
    "playwright": "^1.53.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^6.4.1"
  }
}
